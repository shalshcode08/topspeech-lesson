    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.0.0",
    "sass": "^1.77.0",
    "typescript": "^5.5.4",
    "vite": "^6.0.0",
    "wrangler": "^4.91.0"
  }
}
